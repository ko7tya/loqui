# Telegram — notify on new signups via Bot API.
# Create a bot with @BotFather, then open a chat with it and grab the chat id
# (https://api.telegram.org/bot<TOKEN>/getUpdates). Leave both blank in dev to
# log stubbed messages to the server console instead of hitting the API.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Vercel KV (Upstash Redis) — persistent submission outbox + waitlist counter.
# If either is missing, the server falls back to an in-memory Map keyed by the
# process — fine for local dev, lost on restart.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Cron secret — required by /api/cron/retry-submissions.
# Generate with `openssl rand -hex 32`. The cron route rejects every request
# whose `Authorization: Bearer <value>` header does not match this.
CRON_SECRET=

# Claude (optional, enables real AI plan generation when set).
# Without this the /api/plan route returns the deterministic template.
# ANTHROPIC_API_KEY=
